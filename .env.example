# Copy to .env and fill in your values. The SDK loads .env from the directory
# you run `kovio` in. Shell env vars take precedence over anything set here.
#
# Without KOVIO_API_URL + KOVIO_API_KEY the SDK runs local-only (bundled
# default creative, local event log) — no cloud calls.

# Required for cloud mode
KOVIO_API_URL=https://kovio-api.fly.dev
KOVIO_API_KEY=kov_live_replace_me

# Optional
# KOVIO_ROBOT_ID=my-laptop-test   # defaults to this machine's hostname
# KOVIO_API_TIMEOUT=8             # seconds before an API call gives up
# KOVIO_CAMPAIGN_TTL=300          # seconds between campaign refreshes
