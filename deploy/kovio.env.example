# Kovio agent configuration — copy to /etc/kovio/kovio.env and fill in.
# Loaded by the systemd service (deploy/kovio-agent.service).

# --- Cloud (kovio-cloud) ---
KOVIO_API_URL=https://api.kovio.dev
KOVIO_API_KEY=kov_live_REPLACE_ME        # the fleet's SDK API key
KOVIO_ROBOT_ID=go2-001                    # stable per-robot id (defaults to hostname)

# --- Perception ---
# 'rich' = depth-camera + lidar fusion with interaction metrics (this build).
# Falls back gracefully: no pose model -> no gestures; no lidar -> no crowd.
KOVIO_PERCEPTION=rich

# Feature gates are read by RichPerceptionAdapter defaults; to disable a branch,
# run a thin launcher instead of `kovio serve` (see deploy/README.md). Defaults:
#   phone=on  gestures=on  gaze=on  lidar=on

# --- Screen ---
# browser = full-screen Chromium kiosk; pi_touchscreen, hdmi, etc. also valid.
KOVIO_SCREEN=browser

# --- Optional ---
# KOVIO_API_TIMEOUT=8.0
# KOVIO_CAMPAIGN_TTL=300
